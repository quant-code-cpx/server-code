/// 事件信号触发规则
model EventSignalRule {
  id          Int                   @id @default(autoincrement())
  userId      Int                   @map("user_id")
  name        String                @db.VarChar(128)
  description String?               @db.Text

  /// 事件类型（EventType 枚举值字符串）
  eventType   String                @map("event_type") @db.VarChar(32)
  /// 额外筛选条件 JSON，例如 {"type": "预增", "pChangeMin": {"gte": 50}}
  conditions  Json                  @default("{}")
  /// 信号方向：BUY / SELL / WATCH
  signalType  String                @map("signal_type") @db.VarChar(8)  @default("WATCH")
  /// 规则状态
  status      EventSignalRuleStatus @default(ACTIVE)

  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  signals     EventSignal[]

  @@index([userId])
  @@index([status, eventType])
  @@map("event_signal_rules")
}

/// 事件信号记录（已触发的信号）
model EventSignal {
  id          Int      @id @default(autoincrement())
  ruleId      Int      @map("rule_id")
  tsCode      String   @map("ts_code") @db.VarChar(16)
  stockName   String?  @map("stock_name") @db.VarChar(64)
  eventDate   DateTime @map("event_date") @db.Date
  signalType  String   @map("signal_type") @db.VarChar(8)
  /// 触发时的事件摘要 JSON
  eventDetail Json     @map("event_detail") @default("{}")

  triggeredAt DateTime @default(now()) @map("triggered_at")

  rule        EventSignalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([tsCode])
  @@index([triggeredAt])
  @@map("event_signals")
}

enum EventSignalRuleStatus {
  ACTIVE
  PAUSED
  DELETED
}
