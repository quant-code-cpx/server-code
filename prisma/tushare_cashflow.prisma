// 现金流量表（来自 cashflow 接口）
// 以单只股票历史报表回补为主，保留最近若干年季度/年报的完整现金流量表快照
model Cashflow {
  id                      BigInt    @id @default(autoincrement())
  tsCode                  String    @map("ts_code") @db.VarChar(16)
  annDate                 DateTime? @map("ann_date") @db.Date
  fAnnDate                DateTime? @map("f_ann_date") @db.Date
  endDate                 DateTime  @map("end_date") @db.Date
  compType                String?   @map("comp_type") @db.VarChar(16)
  reportType              String?   @map("report_type") @db.VarChar(16)
  endType                 String?   @map("end_type") @db.VarChar(16)
  netProfit               Float?    @map("net_profit")
  finanExp                Float?    @map("finan_exp")
  cFrSaleSg               Float?    @map("c_fr_sale_sg")
  recpTaxRends            Float?    @map("recp_tax_rends")
  nDeposIncrFi            Float?    @map("n_depos_incr_fi")
  nIncrLoansCb            Float?    @map("n_incr_loans_cb")
  nIncBorrOthFi           Float?    @map("n_inc_borr_oth_fi")
  premFrOrigContr         Float?    @map("prem_fr_orig_contr")
  nIncrInsuredDep         Float?    @map("n_incr_insured_dep")
  nReinsurPrem            Float?    @map("n_reinsur_prem")
  nIncrDispTfa            Float?    @map("n_incr_disp_tfa")
  ifcCashIncr             Float?    @map("ifc_cash_incr")
  nIncrDispFaas           Float?    @map("n_incr_disp_faas")
  nIncrLoansOthBank       Float?    @map("n_incr_loans_oth_bank")
  nCapIncrRepur           Float?    @map("n_cap_incr_repur")
  cFrOthOperateA          Float?    @map("c_fr_oth_operate_a")
  cInfFrOperateA          Float?    @map("c_inf_fr_operate_a")
  cPaidGoodsS             Float?    @map("c_paid_goods_s")
  cPaidToForEmpl          Float?    @map("c_paid_to_for_empl")
  cPaidForTaxes           Float?    @map("c_paid_for_taxes")
  nIncrCltLoanAdv         Float?    @map("n_incr_clt_loan_adv")
  nIncrDepCbob            Float?    @map("n_incr_dep_cbob")
  cPayClaimsOrigInco      Float?    @map("c_pay_claims_orig_inco")
  payHandlingChrg         Float?    @map("pay_handling_chrg")
  payCommInsurPlcy        Float?    @map("pay_comm_insur_plcy")
  othCashPayOperAct       Float?    @map("oth_cash_pay_oper_act")
  stCashOutAct            Float?    @map("st_cash_out_act")
  nCashflowAct            Float?    @map("n_cashflow_act")
  othRecpRalInvAct        Float?    @map("oth_recp_ral_inv_act")
  cDispWithdrwlInvest     Float?    @map("c_disp_withdrwl_invest")
  cRecpReturnInvest       Float?    @map("c_recp_return_invest")
  nRecpDispFiolta         Float?    @map("n_recp_disp_fiolta")
  nRecpDispSobu           Float?    @map("n_recp_disp_sobu")
  stotInflowsInvAct       Float?    @map("stot_inflows_inv_act")
  cPayAcqConstFiolta      Float?    @map("c_pay_acq_const_fiolta")
  cPaidInvest             Float?    @map("c_paid_invest")
  nDispSubsOthBiz         Float?    @map("n_disp_subs_oth_biz")
  othPayRalInvAct         Float?    @map("oth_pay_ral_inv_act")
  nIncrPledgeLoan         Float?    @map("n_incr_pledge_loan")
  stotOutInvAct           Float?    @map("stot_out_inv_act")
  nCashflowInvAct         Float?    @map("n_cashflow_inv_act")
  cRecpBorrow             Float?    @map("c_recp_borrow")
  procIssueBonds          Float?    @map("proc_issue_bonds")
  othCashRecpRalFncAct    Float?    @map("oth_cash_recp_ral_fnc_act")
  stotCashInFncAct        Float?    @map("stot_cash_in_fnc_act")
  freeCashflow            Float?    @map("free_cashflow")
  cPrepayAmtBorr          Float?    @map("c_prepay_amt_borr")
  cPayDistDpcpIntExp      Float?    @map("c_pay_dist_dpcp_int_exp")
  inclDvdProfitPaidScMs   Float?    @map("incl_dvd_profit_paid_sc_ms")
  othCashpayRalFncAct     Float?    @map("oth_cashpay_ral_fnc_act")
  stotCashoutFncAct       Float?    @map("stot_cashout_fnc_act")
  nCashFlowsFncAct        Float?    @map("n_cash_flows_fnc_act")
  effFxFluCash            Float?    @map("eff_fx_flu_cash")
  nIncrCashCashEqu        Float?    @map("n_incr_cash_cash_equ")
  cCashEquBegPeriod       Float?    @map("c_cash_equ_beg_period")
  cCashEquEndPeriod       Float?    @map("c_cash_equ_end_period")
  cRecpCapContrib         Float?    @map("c_recp_cap_contrib")
  inclCashRecSaims        Float?    @map("incl_cash_rec_saims")
  unconInvestLoss         Float?    @map("uncon_invest_loss")
  provDeprAssets          Float?    @map("prov_depr_assets")
  deprFaCogaDpba          Float?    @map("depr_fa_coga_dpba")
  amortIntangAssets       Float?    @map("amort_intang_assets")
  ltAmortDeferredExp      Float?    @map("lt_amort_deferred_exp")
  decrDeferredExp         Float?    @map("decr_deferred_exp")
  incrAccExp              Float?    @map("incr_acc_exp")
  lossDispFiolta          Float?    @map("loss_disp_fiolta")
  lossScrFa               Float?    @map("loss_scr_fa")
  lossFvChg               Float?    @map("loss_fv_chg")
  investLoss              Float?    @map("invest_loss")
  decrDefIncTaxAssets     Float?    @map("decr_def_inc_tax_assets")
  incrDefIncTaxLiab       Float?    @map("incr_def_inc_tax_liab")
  decrInventories         Float?    @map("decr_inventories")
  decrOperPayable         Float?    @map("decr_oper_payable")
  incrOperPayable         Float?    @map("incr_oper_payable")
  others                  Float?
  imNetCashflowOperAct    Float?    @map("im_net_cashflow_oper_act")
  convDebtIntoCap         Float?    @map("conv_debt_into_cap")
  convCopbondsDueWithin1y Float?    @map("conv_copbonds_due_within_1y")
  faFncLeases             Float?    @map("fa_fnc_leases")
  imNIncrCashEqu          Float?    @map("im_n_incr_cash_equ")
  netDismCapitalAdd       Float?    @map("net_dism_capital_add")
  netCashReceSec          Float?    @map("net_cash_rece_sec")
  creditImpALoss          Float?    @map("credit_impa_loss")
  useRightAssetDep        Float?    @map("use_right_asset_dep")
  othLossAsset            Float?    @map("oth_loss_asset")
  endBalCash              Float?    @map("end_bal_cash")
  begBalCash              Float?    @map("beg_bal_cash")
  endBalCashEqu           Float?    @map("end_bal_cash_equ")
  begBalCashEqu           Float?    @map("beg_bal_cash_equ")
  updateFlag              String?   @map("update_flag") @db.VarChar(8)
  syncedAt                DateTime  @default(now()) @map("synced_at")

  @@index([tsCode, endDate(sort: Desc)])
  @@index([annDate])
  @@index([fAnnDate])
  @@map("cashflow_reports")
}
