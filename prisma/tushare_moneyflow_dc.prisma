// 个股资金流向——东财数据（来自 moneyflow_dc 接口）
model MoneyflowDc {
  tsCode           String   @map("ts_code") @db.VarChar(16)
  tradeDate        DateTime @map("trade_date") @db.Date
  name             String?  @db.VarChar(64)
  pctChange        Float?   @map("pct_change")
  close            Float?
  netAmount        Float?   @map("net_amount")
  netAmountRate    Float?   @map("net_amount_rate")
  buyElgAmount     Float?   @map("buy_elg_amount")
  buyElgAmountRate Float?   @map("buy_elg_amount_rate")
  buyLgAmount      Float?   @map("buy_lg_amount")
  buyLgAmountRate  Float?   @map("buy_lg_amount_rate")
  buyMdAmount      Float?   @map("buy_md_amount")
  buyMdAmountRate  Float?   @map("buy_md_amount_rate")
  buySmAmount      Float?   @map("buy_sm_amount")
  buySmAmountRate  Float?   @map("buy_sm_amount_rate")
  syncedAt         DateTime @default(now()) @map("synced_at")

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
  @@map("stock_capital_flows")
}
