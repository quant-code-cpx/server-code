// 融资融券交易明细（来自 margin_detail 接口，需 Tushare 2000 积分）
model MarginDetail {
  tsCode    String   @map("ts_code")    @db.VarChar(12)
  tradeDate DateTime @map("trade_date") @db.Date

  rzye   Float? @map("rzye")   // 融资余额（元）
  rzmre  Float? @map("rzmre")  // 融资买入额（元）
  rzche  Float? @map("rzche")  // 融资偿还额（元）
  rzjmre Float? @map("rzjmre") // 融资净买入（元）
  rqye   Float? @map("rqye")   // 融券余额（元）
  rqmcl  Float? @map("rqmcl")  // 融券卖出量（股）
  rqchl  Float? @map("rqchl")  // 融券偿还量（股）
  rqyl   Float? @map("rqyl")   // 融券余量（股）
  rzrqye Float? @map("rzrqye") // 融资融券余额（元）
  rzrqyl Float? @map("rzrqyl") // 融资融券余量（股）

  syncedAt DateTime @default(now()) @map("synced_at")

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
  @@index([tsCode, tradeDate(sort: Desc)])
  @@map("margin_detail")
}
