PORT=3000
GLOBAL_PREFIX=api
NODE_ENV=development
PROCESS_ROLE=all                                  # api | agent-worker | scheduler | all；生产建议拆分

# JWT Tokens（必填，建议使用 openssl rand -base64 48 生成随机值，长度不低于 32 字符）
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRE=43200                          # 12 小时（秒），Refresh Token 有效期
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRE=1800                            # 30 分钟（秒），Access Token 有效期

# CORS（生产环境配置前端域名，多个域名用逗号分隔；未配置时生产环境 CORS 禁用）
# 示例：CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=https://your-frontend-domain.com

# Redis（非开发环境必填；建议使用强随机密码）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USERNAME=default

# Database (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL="postgresql://postgres:your_postgres_password@localhost:5432/quant_db?schema=public"
AGENT_AUDIT_PAYLOAD_MODE=HASH_ONLY
# Agent Model Gateway（开发默认 fake；真实 key 只放 secret/.env，禁止提交）
AGENT_MODEL_PROVIDER=fake
AGENT_MODEL_BASE_URL=
AGENT_MODEL_BASE_URL_ALLOWLIST=
AGENT_MODEL_API_KEY=
AGENT_MODEL_DEFAULT=fake-deterministic-v1
AGENT_MODEL_TIMEOUT_MS=120000
AGENT_MODEL_MAX_RETRIES=2
AGENT_MODEL_RETRY_BASE_MS=200
AGENT_MODEL_CAPABILITIES=STREAMING,STRUCTURED_OUTPUT,TOOL_CALLING
AGENT_MODEL_CONTEXT_WINDOW=32768
AGENT_MODEL_MAX_OUTPUT_TOKENS=4096
AGENT_MODEL_REASONING_EFFORTS=LOW,MEDIUM,HIGH
AGENT_MODEL_DATA_CLASSES=PUBLIC,USER_PRIVATE,PORTFOLIO_SENSITIVE
# Agent Run / Event Store
AGENT_RUN_LEASE_MS=30000
AGENT_LEASE_HEARTBEAT_MS=10000
AGENT_EVENT_REPLAY_LIMIT=100
AGENT_RUN_MAX_DURATION_MS=180000
AGENT_MAX_STEPS=32
AGENT_MAX_TOOL_CALLS=20
AGENT_MAX_PARALLEL_TOOLS=3
AGENT_MAX_INPUT_TOKENS=32768
AGENT_MAX_COST_PER_RUN=10
# Agent REST API 配额（生产环境必须显式配置）
AGENT_MAX_ACTIVE_RUNS_PER_USER=3
AGENT_DEFAULT_DAILY_BUDGET=20
# Agent BullMQ Worker（AGENT_QUEUE_REDIS_URL 为空时复用上方 Redis）
AGENT_QUEUE_REDIS_URL=
AGENT_QUEUE_PREFIX=quant:agent
AGENT_WORKER_CONCURRENCY=2
AGENT_JOB_TIMEOUT_MS=180000
AGENT_JOB_ATTEMPTS=5
AGENT_JOB_BACKOFF_MS=2000
AGENT_RECONCILE_INTERVAL_MS=10000
AGENT_RECONCILE_BATCH_SIZE=100
# Agent Tool Registry / Executor（空 allowlist = 默认拒绝）
AGENT_TOOLS_ENABLED=
AGENT_TOOL_MAX_CALLS_PER_RUN=20
AGENT_TOOL_DEFAULT_TIMEOUT_MS=10000
AGENT_TOOL_MAX_RESULT_BYTES=256000
AGENT_TOOL_MAX_CONCURRENT_PER_RUN=3
AGENT_TOOL_PRICE_MAX_BARS=5000
AGENT_TOOL_MARKET_CACHE_TTL_SECONDS=300
AGENT_TOOL_FINANCIAL_MAX_PERIODS=20
AGENT_TOOL_MONEYFLOW_MAX_DAYS=250
AGENT_QUANT_MAX_POINTS=10000
AGENT_VALUATION_MIN_SAMPLES=60
# Agent Web Search / Controlled Fetch（默认 disabled；真实 key 只放 secret/.env）
AGENT_SEARCH_PROVIDER=disabled
AGENT_SEARCH_API_KEY=
AGENT_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
AGENT_SEARCH_TIMEOUT_MS=10000
AGENT_FETCH_MAX_BYTES=1000000
AGENT_FETCH_MAX_REDIRECTS=3
AGENT_URL_TOKEN_SECRET=
AGENT_URL_TOKEN_TTL_SECONDS=900
PRISMA_CONNECTION_LIMIT=30                        # Prisma 连接池上限（生产建议 30-50）
PRISMA_POOL_TIMEOUT=20                            # 等待连接池空闲连接的秒数
PRISMA_CONNECT_TIMEOUT=10                         # 建立数据库连接的秒数
PRISMA_TRANSACTION_MAX_WAIT_MS=10000             # 事务排队等待连接的毫秒数
PRISMA_TRANSACTION_TIMEOUT_MS=30000              # 事务执行超时（毫秒）

# Tushare Pro（https://tushare.pro 注册后获取 token）
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_BASE_URL=http://api.tushare.pro
TUSHARE_TIMEOUT=10000
TUSHARE_REQUEST_INTERVAL_MS=350
TUSHARE_RATE_LIMIT_RETRY_DELAY_MS=65000
TUSHARE_MAX_RETRIES=3
TUSHARE_SYNC_ENABLED=false
TUSHARE_SYNC_START_DATE=19900101                  # 历史补数起始日期（YYYYMMDD）
TUSHARE_SYNC_CRON=0 30 18 * * *                  # 默认每天 18:30 触发，代码内会再判断是否交易日
TUSHARE_SYNC_TIME_ZONE=Asia/Shanghai

# 超级管理员初始化（首次启动时若数据库中无超级管理员则自动创建）
SUPER_ADMIN_ACCOUNT=superadmin
SUPER_ADMIN_PASSWORD=your_super_admin_password   # 不能少于8位
SUPER_ADMIN_NICKNAME=超级管理员

# Docker 数据目录（由 docker-compose.yml 强制从环境变量读取）
DATA_POSTGRES_DIR=../data/postgres
DATA_REDIS_DIR=../data/redis
DATA_REDIS_LOGS_DIR=../data/redis/logs

# 可观测性（HTTP 请求日志）
LOG_HTTP_REQUESTS=true                            # 是否记录 HTTP 请求日志（默认开启）
LOG_HTTP_BODY=false                               # 是否记录请求 Body（敏感字段自动脱敏，默认关闭）
