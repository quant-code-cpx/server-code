// 资产负债表（来自 balancesheet 接口）
// 以单只股票历史报表回补为主，保留最近若干年季度/年报的完整资产负债表快照
model BalanceSheet {
  id                   BigInt    @id @default(autoincrement())
  tsCode               String    @map("ts_code") @db.VarChar(16)
  annDate              DateTime? @map("ann_date") @db.Date
  fAnnDate             DateTime? @map("f_ann_date") @db.Date
  endDate              DateTime  @map("end_date") @db.Date
  reportType           String?   @map("report_type") @db.VarChar(16)
  compType             String?   @map("comp_type") @db.VarChar(16)
  endType              String?   @map("end_type") @db.VarChar(16)
  totalShare           Float?    @map("total_share")
  capRese              Float?    @map("cap_rese")
  undistrPorfit        Float?    @map("undistr_porfit")
  surplusRese          Float?    @map("surplus_rese")
  specialRese          Float?    @map("special_rese")
  moneyCap             Float?    @map("money_cap")
  tradAsset            Float?    @map("trad_asset")
  notesReceiv          Float?    @map("notes_receiv")
  accountsReceiv       Float?    @map("accounts_receiv")
  othReceiv            Float?    @map("oth_receiv")
  prepayment           Float?
  divReceiv            Float?    @map("div_receiv")
  intReceiv            Float?    @map("int_receiv")
  inventories          Float?
  amorExp              Float?    @map("amor_exp")
  ncaWithin1y          Float?    @map("nca_within_1y")
  settRsrv             Float?    @map("sett_rsrv")
  loantoOthBankFi      Float?    @map("loanto_oth_bank_fi")
  premiumReceiv        Float?    @map("premium_receiv")
  reinsurReceiv        Float?    @map("reinsur_receiv")
  reinsurResReceiv     Float?    @map("reinsur_res_receiv")
  purResaleFa          Float?    @map("pur_resale_fa")
  othCurAssets         Float?    @map("oth_cur_assets")
  totalCurAssets       Float?    @map("total_cur_assets")
  faAvailForSale       Float?    @map("fa_avail_for_sale")
  htmInvest            Float?    @map("htm_invest")
  ltEqtInvest          Float?    @map("lt_eqt_invest")
  investRealEstate     Float?    @map("invest_real_estate")
  timeDeposits         Float?    @map("time_deposits")
  othAssets            Float?    @map("oth_assets")
  ltRec                Float?    @map("lt_rec")
  fixAssets            Float?    @map("fix_assets")
  cip                  Float?
  constMaterials       Float?    @map("const_materials")
  fixedAssetsDisp      Float?    @map("fixed_assets_disp")
  producBioAssets      Float?    @map("produc_bio_assets")
  oilAndGasAssets      Float?    @map("oil_and_gas_assets")
  intanAssets          Float?    @map("intan_assets")
  rAndD                Float?    @map("r_and_d")
  goodwill             Float?
  ltAmorExp            Float?    @map("lt_amor_exp")
  deferTaxAssets       Float?    @map("defer_tax_assets")
  decrInDisbur         Float?    @map("decr_in_disbur")
  othNca               Float?    @map("oth_nca")
  totalNca             Float?    @map("total_nca")
  cashReserCb          Float?    @map("cash_reser_cb")
  deposInOthBfi        Float?    @map("depos_in_oth_bfi")
  precMetals           Float?    @map("prec_metals")
  derivAssets          Float?    @map("deriv_assets")
  rrReinsUnePrem       Float?    @map("rr_reins_une_prem")
  rrReinsOutstdCla     Float?    @map("rr_reins_outstd_cla")
  rrReinsLinsLiab      Float?    @map("rr_reins_lins_liab")
  rrReinsLthinsLiab    Float?    @map("rr_reins_lthins_liab")
  refundDepos          Float?    @map("refund_depos")
  phPledgeLoans        Float?    @map("ph_pledge_loans")
  refundCapDepos       Float?    @map("refund_cap_depos")
  indepAcctAssets      Float?    @map("indep_acct_assets")
  clientDepos          Float?    @map("client_depos")
  clientProv           Float?    @map("client_prov")
  transacSeatFee       Float?    @map("transac_seat_fee")
  investAsReceiv       Float?    @map("invest_as_receiv")
  totalAssets          Float?    @map("total_assets")
  ltBorr               Float?    @map("lt_borr")
  stBorr               Float?    @map("st_borr")
  cbBorr               Float?    @map("cb_borr")
  deposIbDeposits      Float?    @map("depos_ib_deposits")
  loanOthBank          Float?    @map("loan_oth_bank")
  tradingFl            Float?    @map("trading_fl")
  notesPayable         Float?    @map("notes_payable")
  acctPayable          Float?    @map("acct_payable")
  advReceipts          Float?    @map("adv_receipts")
  soldForRepurFa       Float?    @map("sold_for_repur_fa")
  commPayable          Float?    @map("comm_payable")
  payrollPayable       Float?    @map("payroll_payable")
  taxesPayable         Float?    @map("taxes_payable")
  intPayable           Float?    @map("int_payable")
  divPayable           Float?    @map("div_payable")
  othPayable           Float?    @map("oth_payable")
  accExp               Float?    @map("acc_exp")
  deferredInc          Float?    @map("deferred_inc")
  stBondsPayable       Float?    @map("st_bonds_payable")
  payableToReinsurer   Float?    @map("payable_to_reinsurer")
  rsrvInsurCont        Float?    @map("rsrv_insur_cont")
  actingTradingSec     Float?    @map("acting_trading_sec")
  actingUwSec          Float?    @map("acting_uw_sec")
  nonCurLiabDue1y      Float?    @map("non_cur_liab_due_1y")
  othCurLiab           Float?    @map("oth_cur_liab")
  totalCurLiab         Float?    @map("total_cur_liab")
  bondPayable          Float?    @map("bond_payable")
  ltPayable            Float?    @map("lt_payable")
  specificPayables     Float?    @map("specific_payables")
  estimatedLiab        Float?    @map("estimated_liab")
  deferTaxLiab         Float?    @map("defer_tax_liab")
  deferIncNonCurLiab   Float?    @map("defer_inc_non_cur_liab")
  othNcl               Float?    @map("oth_ncl")
  totalNcl             Float?    @map("total_ncl")
  deposOthBfi          Float?    @map("depos_oth_bfi")
  derivLiab            Float?    @map("deriv_liab")
  depos                Float?
  agencyBusLiab        Float?    @map("agency_bus_liab")
  othLiab              Float?    @map("oth_liab")
  premRecivAdva        Float?    @map("prem_receiv_adva")
  deposReceived        Float?    @map("depos_received")
  phInvest             Float?    @map("ph_invest")
  reserUnePrem         Float?    @map("reser_une_prem")
  reserOutstdClaims    Float?    @map("reser_outstd_claims")
  reserLinsLiab        Float?    @map("reser_lins_liab")
  reserLthinsLiab      Float?    @map("reser_lthins_liab")
  indeptAccLiab        Float?    @map("indept_acc_liab")
  pledgeBorr           Float?    @map("pledge_borr")
  indemPayable         Float?    @map("indem_payable")
  policyDivPayable     Float?    @map("policy_div_payable")
  totalLiab            Float?    @map("total_liab")
  treasuryShare        Float?    @map("treasury_share")
  ordinRiskReser       Float?    @map("ordin_risk_reser")
  forexDiffer          Float?    @map("forex_differ")
  investLossUnconf     Float?    @map("invest_loss_unconf")
  minorityInt          Float?    @map("minority_int")
  totalHldrEqyExcMinInt Float?   @map("total_hldr_eqy_exc_min_int")
  totalHldrEqyIncMinInt Float?   @map("total_hldr_eqy_inc_min_int")
  totalLiabHldrEqy     Float?    @map("total_liab_hldr_eqy")
  ltPayrollPayable     Float?    @map("lt_payroll_payable")
  othCompIncome        Float?    @map("oth_comp_income")
  othEqtTools          Float?    @map("oth_eqt_tools")
  othEqtToolsPShr      Float?    @map("oth_eqt_tools_p_shr")
  lendingFunds         Float?    @map("lending_funds")
  accReceivable        Float?    @map("acc_receivable")
  stFinPayable         Float?    @map("st_fin_payable")
  payables             Float?
  hfsAssets            Float?    @map("hfs_assets")
  hfsSales             Float?    @map("hfs_sales")
  costFinAssets        Float?    @map("cost_fin_assets")
  fairValueFinAssets   Float?    @map("fair_value_fin_assets")
  cipTotal             Float?    @map("cip_total")
  othPayTotal          Float?    @map("oth_pay_total")
  longPayTotal         Float?    @map("long_pay_total")
  debtInvest           Float?    @map("debt_invest")
  othDebtInvest        Float?    @map("oth_debt_invest")
  othEqInvest          Float?    @map("oth_eq_invest")
  othIlliqFinAssets    Float?    @map("oth_illiq_fin_assets")
  othEqPpbond          Float?    @map("oth_eq_ppbond")
  receivFinancing      Float?    @map("receiv_financing")
  useRightAssets       Float?    @map("use_right_assets")
  leaseLiab            Float?    @map("lease_liab")
  contractAssets       Float?    @map("contract_assets")
  contractLiab         Float?    @map("contract_liab")
  accountsRecivBill    Float?    @map("accounts_receiv_bill")
  accountsPay          Float?    @map("accounts_pay")
  othRcvTotal          Float?    @map("oth_rcv_total")
  fixAssetsTotal       Float?    @map("fix_assets_total")
  updateFlag           String?   @map("update_flag") @db.VarChar(8)
  syncedAt             DateTime  @default(now()) @map("synced_at")

  @@index([tsCode, endDate(sort: Desc)])
  @@index([tsCode, reportType, endDate(sort: Desc)])
  @@index([annDate])
  @@index([fAnnDate])
  @@map("balance_sheet_reports")
}
