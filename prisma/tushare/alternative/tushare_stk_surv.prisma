// 机构调研（stk_surv 接口）
// 注意：该接口按日期范围批量获取，不支持 trade_date 参数，需传 start_date/end_date
model StkSurv {
  tsCode       String   @map("ts_code") @db.VarChar(16)
  survDate     DateTime @map("surv_date") @db.Date
  name         String?  @map("name") @db.VarChar(64)
  fundVisitors String?  @map("fund_visitors") @db.VarChar(256)
  recePlace    String?  @map("rece_place") @db.VarChar(256)
  receMode     String?  @map("rece_mode") @db.VarChar(256)
  receOrg      String?  @map("rece_org") @db.VarChar(256)
  orgType      String?  @map("org_type") @db.VarChar(64)
  compRece     String?  @map("comp_rece") @db.VarChar(512)
  syncedAt     DateTime @default(now()) @map("synced_at")

  @@id([tsCode, survDate])
  @@index([survDate])
  @@index([tsCode, survDate(sort: Desc)])
  @@map("stk_surv")
}
