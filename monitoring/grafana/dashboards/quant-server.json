            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(http_request_errors_total{app=\"quant-server\"}[5m])) / sum(rate(http_requests_total{app=\"quant-server\"}[5m])) * 100",
          "legendFormat": "错误率 %"
        }
      ],
      "title": "HTTP 错误率",
      "type": "stat"
    },
    {
