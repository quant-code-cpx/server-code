// 分钟级行情（stk_mins 接口）
model StkMins {
  tsCode    String   @map("ts_code") @db.VarChar(16)
  tradeTime DateTime @map("trade_time")
  freq      String   @db.VarChar(8)
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  vol       Float?
  amount    Float?
  syncedAt  DateTime @default(now()) @map("synced_at")

  @@id([tsCode, tradeTime, freq])
  @@index([tsCode, tradeTime(sort: Desc)])
  @@map("stk_mins")
}
