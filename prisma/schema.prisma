// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

enum UserStatus {
  ACTIVE      // 正常
  DEACTIVATED // 禁用
  DELETED     // 已注销
}

enum UserRole {
  SUPER_ADMIN // 超级管理员（顶级权限，有且仅有一个）
  ADMIN       // 管理员
  USER        // 普通用户
}

model User {
  id             Int        @id @default(autoincrement())
  account        String     @unique @db.VarChar(64)  // 登录账号
  password       String     @db.VarChar(255)          // 密码（bcrypt 加密）
  nickname       String     @db.VarChar(64)           // 昵称
  role           UserRole   @default(USER)            // 用户角色
  status         UserStatus @default(ACTIVE)          // 账号状态
  email          String?    @db.VarChar(128)          // 邮箱（可选）
  wechat         String?    @db.VarChar(64)           // 微信号（可选）
  lastLoginAt    DateTime?                            // 最后登录时间
  backtestQuota  Int        @default(3)               // 回测任务数量限制（仅管理员以上可修改）
  watchlistLimit Int        @default(10)              // 监控股票数量限制（管理员以上不受限制）
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("users")
}
