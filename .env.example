PORT=3000
GLOBAL_PREFIX=api
NODE_ENV=development

# JWT Tokens
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRE=43200                          # 12 小时（秒），Refresh Token 有效期
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRE=1800                            # 30 分钟（秒），Access Token 有效期

# CORS（生产环境配置前端域名，多个域名用逗号分隔）
CORS_ORIGIN=https://your-frontend-domain.com

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=default

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/quant_db?schema=public"

# Tushare Pro（https://tushare.pro 注册后获取 token）
TUSHARE_TOKEN=your_tushare_token_here
TUSHARE_BASE_URL=http://api.tushare.pro
TUSHARE_TIMEOUT=10000
