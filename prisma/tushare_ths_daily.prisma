// 同花顺板块指数日线（ths_daily 接口）
model ThsDaily {
  tsCode      String   @map("ts_code") @db.VarChar(24)
  tradeDate   DateTime @map("trade_date") @db.Date
  close       Float?
  open        Float?
  high        Float?
  low         Float?
  preClose    Float?   @map("pre_close")
  avgPrice    Float?   @map("avg_price")
  change      Float?
  pctChg      Float?   @map("pct_chg")
  vol         Float?
  turnoverRate Float?  @map("turnover_rate")
  syncedAt    DateTime @default(now()) @map("synced_at")

  @@id([tsCode, tradeDate])
  @@index([tradeDate])
  @@index([tsCode, tradeDate(sort: Desc)])
  @@map("ths_daily")
}
