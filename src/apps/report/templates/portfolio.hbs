<html lang='zh-CN'>
  <head>
    <meta charset='UTF-8' />
    <title>{{overview.name}} - 组合分析报告</title>
    <style>
      body {
        font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
        margin: 40px;
        color: #333;
        font-size: 14px;
      }
      h1 {
        font-size: 22px;
        border-bottom: 2px solid #1a73e8;
        padding-bottom: 8px;
      }
      h2 {
        font-size: 16px;
        color: #1a73e8;
        margin-top: 28px;
      }
      table {
        border-collapse: collapse;
        width: 100%;
        margin: 12px 0;
      }
      th,
      td {
        border: 1px solid #ddd;
        padding: 6px 10px;
        text-align: right;
      }
      th {
        background: #f5f7fa;
        text-align: center;
        font-weight: 600;
      }
      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
        margin: 12px 0;
      }
      .metric-card {
        background: #f5f7fa;
        border-radius: 6px;
        padding: 12px 16px;
      }
      .metric-card .label {
        font-size: 12px;
        color: #666;
      }
      .metric-card .value {
        font-size: 20px;
        font-weight: 600;
        margin-top: 4px;
      }
      .positive {
        color: #e23;
      }
      .negative {
        color: #0a0;
      }
    </style>
  </head>
  <body>
    <h1>{{overview.name}} 组合分析报告</h1>
    <p>创建日期：{{overview.createdAt}} {{#if overview.description}}&nbsp;|&nbsp; {{overview.description}}{{/if}}</p>

    <div class='grid'>
      <div class='metric-card'><div class='label'>总市值</div><div
          class='value'
        >{{overview.totalMarketValue}}</div></div>
      <div class='metric-card'><div class='label'>总成本</div><div class='value'>{{overview.totalCost}}</div></div>
      <div class='metric-card'><div class='label'>总盈亏</div><div class='value'>{{overview.totalPnl}}</div></div>
    </div>

    <h2>持仓明细</h2>
    <table>
      <thead>
        <tr><th>代码</th><th>名称</th><th>数量</th><th>成本价</th><th>现价</th><th>市值</th><th>权重</th><th
          >盈亏</th><th>盈亏比</th></tr>
      </thead>
      <tbody>
        {{#each holdings}}
          <tr>
            <td>{{this.tsCode}}</td><td style='text-align:left'>{{this.name}}</td>
            <td>{{this.quantity}}</td><td>{{this.costPrice}}</td><td>{{this.currentPrice}}</td>
            <td>{{this.marketValue}}</td><td>{{this.weight}}</td><td>{{this.pnl}}</td><td>{{this.pnlPct}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <h2>行业分布</h2>
    <table>
      <thead><tr><th>行业</th><th>权重</th><th>持仓数</th></tr></thead>
      <tbody>
        {{#each industryDistribution}}
          <tr><td style='text-align:left'>{{this.industry}}</td><td>{{this.weight}}</td><td>{{this.count}}</td></tr>
        {{/each}}
      </tbody>
    </table>
  </body>
</html>