#!/bin/sh
# Pre-push hook: 仅运行与本次推送变更相关的测试（增量测试）
# 使用 jest --findRelatedTests 检测受影响的 spec 文件并执行

# 找到本地分支与远端追踪分支的差异
UPSTREAM=$(git rev-parse --abbrev-ref @{upstream} 2>/dev/null)

if [ -n "$UPSTREAM" ]; then
  BASE="$UPSTREAM"
else
  # 尚未设置上游（新分支第一次推送）：以 origin/main 作为基准，
  # 确保分支上所有 commit 的变更都能被检测到
  BASE=$(git rev-parse origin/main 2>/dev/null)
fi

if [ -n "$BASE" ]; then
  SRC_FILES=$(git diff --name-only "$BASE..HEAD" 2>/dev/null \
    | grep '^src/.*\.ts$' \
    | grep -v '\.spec\.ts$' \
    | tr '\n' ' ')
else
  # 找不到比较基准（例如离线环境或全新仓库），回退为全量测试
  echo "🔍 无法确定比较基准，运行全量测试..."
  pnpm test --passWithNoTests
  exit $?
fi

if [ -z "$(echo "$SRC_FILES" | tr -d ' ')" ]; then
  echo "🔍 未检测到 src/ 源文件变更，跳过增量测试"
  exit 0
fi

echo "🧪 运行增量测试，受影响的源文件："
echo "   $SRC_FILES"

# shellcheck disable=SC2086
pnpm exec jest --findRelatedTests $SRC_FILES --passWithNoTests --forceExit

STATUS=$?
if [ $STATUS -ne 0 ]; then
  echo "❌ 测试失败，推送已中止。请修复后重试。"
  exit 1
fi

echo "✅ 增量测试全部通过"
