// 利润表（来自 income 接口）
// 以单只股票历史报表回补为主，保留最近若干年季度/年报的完整利润表快照
model Income {
  id                     BigInt    @id @default(autoincrement())
  tsCode                 String    @map("ts_code") @db.VarChar(16)
  annDate                DateTime? @map("ann_date") @db.Date
  fAnnDate               DateTime? @map("f_ann_date") @db.Date
  endDate                DateTime  @map("end_date") @db.Date
  reportType             String?   @map("report_type") @db.VarChar(16)
  compType               String?   @map("comp_type") @db.VarChar(16)
  endType                String?   @map("end_type") @db.VarChar(16)
  basicEps               Float?    @map("basic_eps")
  dilutedEps             Float?    @map("diluted_eps")
  totalRevenue           Float?    @map("total_revenue")
  revenue                Float?
  intIncome              Float?    @map("int_income")
  premEarned             Float?    @map("prem_earned")
  commIncome             Float?    @map("comm_income")
  nCommisIncome          Float?    @map("n_commis_income")
  nOthIncome             Float?    @map("n_oth_income")
  nOthBIncome            Float?    @map("n_oth_b_income")
  premIncome             Float?    @map("prem_income")
  outPrem                Float?    @map("out_prem")
  unePremReser           Float?    @map("une_prem_reser")
  reinsIncome            Float?    @map("reins_income")
  nSecTbIncome           Float?    @map("n_sec_tb_income")
  nSecUwIncome           Float?    @map("n_sec_uw_income")
  nAssetMgIncome         Float?    @map("n_asset_mg_income")
  othBIncome             Float?    @map("oth_b_income")
  fvValueChgGain         Float?    @map("fv_value_chg_gain")
  investIncome           Float?    @map("invest_income")
  assInvestIncome        Float?    @map("ass_invest_income")
  forexGain              Float?    @map("forex_gain")
  totalCogs              Float?    @map("total_cogs")
  operCost               Float?    @map("oper_cost")
  intExp                 Float?    @map("int_exp")
  commExp                Float?    @map("comm_exp")
  bizTaxSurchg           Float?    @map("biz_tax_surchg")
  sellExp                Float?    @map("sell_exp")
  adminExp               Float?    @map("admin_exp")
  finExp                 Float?    @map("fin_exp")
  assetsImpairLoss       Float?    @map("assets_impair_loss")
  premRefund             Float?    @map("prem_refund")
  compensPayout          Float?    @map("compens_payout")
  reserInsurLiab         Float?    @map("reser_insur_liab")
  divPayt                Float?    @map("div_payt")
  reinsExp               Float?    @map("reins_exp")
  operExp                Float?    @map("oper_exp")
  compensPayoutRefu      Float?    @map("compens_payout_refu")
  insurReserRefu         Float?    @map("insur_reser_refu")
  reinsCostRefund        Float?    @map("reins_cost_refund")
  otherBusCost           Float?    @map("other_bus_cost")
  operateProfit          Float?    @map("operate_profit")
  nonOperIncome          Float?    @map("non_oper_income")
  nonOperExp             Float?    @map("non_oper_exp")
  ncaDisploss            Float?    @map("nca_disploss")
  totalProfit            Float?    @map("total_profit")
  incomeTax              Float?    @map("income_tax")
  nIncome                Float?    @map("n_income")
  nIncomeAttrP           Float?    @map("n_income_attr_p")
  minorityGain           Float?    @map("minority_gain")
  othComprIncome         Float?    @map("oth_compr_income")
  tComprIncome           Float?    @map("t_compr_income")
  comprIncAttrP          Float?    @map("compr_inc_attr_p")
  comprIncAttrMS         Float?    @map("compr_inc_attr_m_s")
  ebit                   Float?
  ebitda                 Float?
  insuranceExp           Float?    @map("insurance_exp")
  undistProfit           Float?    @map("undist_profit")
  distableProfit         Float?    @map("distable_profit")
  rdExp                  Float?    @map("rd_exp")
  finExpIntExp           Float?    @map("fin_exp_int_exp")
  finExpIntInc           Float?    @map("fin_exp_int_inc")
  transferSurplusRese    Float?    @map("transfer_surplus_rese")
  transferHousingImprest Float?    @map("transfer_housing_imprest")
  transferOth            Float?    @map("transfer_oth")
  adjLossgain            Float?    @map("adj_lossgain")
  withdraLegalSurplus    Float?    @map("withdra_legal_surplus")
  withdraLegalPubfund    Float?    @map("withdra_legal_pubfund")
  withdraBizDevfund      Float?    @map("withdra_biz_devfund")
  withdraReseFund        Float?    @map("withdra_rese_fund")
  withdraOthErsu         Float?    @map("withdra_oth_ersu")
  workersWelfare         Float?    @map("workers_welfare")
  distrProfitShrhder     Float?    @map("distr_profit_shrhder")
  prfsharePayableDvd     Float?    @map("prfshare_payable_dvd")
  comsharePayableDvd     Float?    @map("comshare_payable_dvd")
  capitComstockDiv       Float?    @map("capit_comstock_div")
  netAfterNrLpCorrect    Float?    @map("net_after_nr_lp_correct")
  creditImpaLoss         Float?    @map("credit_impa_loss")
  netExpoHedgingBenefits Float?    @map("net_expo_hedging_benefits")
  othImpairLossAssets    Float?    @map("oth_impair_loss_assets")
  totalOpcost            Float?    @map("total_opcost")
  amodcostFinAssets      Float?    @map("amodcost_fin_assets")
  othIncome              Float?    @map("oth_income")
  assetDispIncome        Float?    @map("asset_disp_income")
  continuedNetProfit     Float?    @map("continued_net_profit")
  endNetProfit           Float?    @map("end_net_profit")
  updateFlag             String?   @map("update_flag") @db.VarChar(8)
  syncedAt               DateTime  @default(now()) @map("synced_at")

  @@index([tsCode, endDate(sort: Desc)])
  @@index([annDate])
  @@index([fAnnDate])
  @@map("income_statement_reports")
}