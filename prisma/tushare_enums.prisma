// Enums used by Tushare models

// 证券交易所
enum StockExchange {
  SSE  // 上海证券交易所
  SZSE // 深圳证券交易所
  BSE  // 北京证券交易所
  HKEX // 香港交易所
}

// 股票上市状态
enum StockListStatus {
  L // 上市（Listed）
  D // 退市（Delisted）
  P // 暂停上市（Paused）
}

// 资金流板块类型
enum MoneyflowContentType {
  INDUSTRY @map("行业")
  CONCEPT  @map("概念")
  REGION   @map("地域")
}

// Tushare 同步任务类型
enum TushareSyncTask {
  STOCK_BASIC
  STOCK_COMPANY
  TRADE_CAL
  DAILY
  WEEKLY
  MONTHLY
  ADJ_FACTOR
  DAILY_BASIC
  INDEX_DAILY
  MONEYFLOW_DC
  MONEYFLOW_IND_DC
  MONEYFLOW_MKT_DC
  MONEYFLOW_HSGT
  INCOME
  BALANCE_SHEET
  CASHFLOW
  EXPRESS
  FINA_INDICATOR
  DIVIDEND
  TOP10_HOLDERS
  TOP10_FLOAT_HOLDERS
  STK_LIMIT
  SUSPEND_D
  INDEX_WEIGHT
  MARGIN_DETAIL
  TOP_LIST
  TOP_INST
  BLOCK_TRADE
  SHARE_FLOAT
  DATA_QUALITY_CHECK
  STK_FACTOR
}

// 同步任务执行结果
enum TushareSyncStatus {
  SUCCESS // 成功
  FAILED  // 失败
  SKIPPED // 跳过（如当日非交易日）
}

// 断点续传进度状态
enum TushareSyncProgressStatus {
  IDLE      // 初始/已完成
  RUNNING   // 进行中
  COMPLETED // 已完成
}

// 失败重试队列状态
enum TushareSyncRetryStatus {
  PENDING   // 待重试
  RETRYING  // 重试中
  SUCCEEDED // 重试成功
  EXHAUSTED // 已耗尽重试次数
}
