// 港股通每日成交（ggt_daily 接口）
// 金额字段单位：亿元，笔数字段单位：万笔（与 Tushare 文档一致）
model GgtDaily {
  tradeDate  DateTime @id @map("trade_date") @db.Date
  buyAmount  Float?   @map("buy_amount")  // 买入成交金额（亿元）
  buyVolume  Float?   @map("buy_volume")  // 买入成交笔数（万笔）
  sellAmount Float?   @map("sell_amount") // 卖出成交金额（亿元）
  sellVolume Float?   @map("sell_volume") // 卖出成交笔数（万笔）
  netAmount  Float?   @map("net_amount")  // 参考字段，暂无文档说明
  netVolume  Float?   @map("net_volume")  // 参考字段，暂无文档说明
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@map("ggt_daily")
}
